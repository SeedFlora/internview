# ── InternView SPA (React + Vite) ────────────────────────────────────────────
# Copy to `.env` and fill in real values. Only VITE_-prefixed vars reach the
# client bundle. `.env` is gitignored — never commit it.

# Base URL of the API. Must exactly match one of the API's CORS_ALLOWED_ORIGINS
# counterparts (scheme+host+port, no trailing slash). axios sends credentials.
VITE_API_BASE_URL=http://localhost:8888

# Public site URL — used only by the prebuild step to emit robots.txt / sitemap.xml
VITE_SITE_URL=http://localhost:5173
