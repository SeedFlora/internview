# ── InternView API (Spring Boot) ─────────────────────────────────────────────
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.

# Database (PostgreSQL) — JDBC URL, e.g. jdbc:postgresql://postgres:5432/internview
DB_URL=jdbc:postgresql://postgres:5432/internview

# JWT — use long random strings for the secrets. Expirations are in milliseconds.
ACCESS_SECRET=change-me-access-secret
REFRESH_SECRET=change-me-refresh-secret
ACCESS_EXP=900000            # 15 minutes
REFRESH_EXP=604800000        # 7 days

# CORS — comma-separated exact origins of the SPA (scheme+host+port, no trailing /)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# MinIO (object storage for certificates)
MINIO_ENDPOINT=http://minio:9000
MINIO_PROXY_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET_NAME=internview

# Mail (password-reset emails). Local dev can point at a Mailpit catcher (:1025,
# no auth). For Gmail use smtp.gmail.com:587 with a 16-char App Password and
# MAIL_SMTP_AUTH=true, MAIL_SMTP_STARTTLS=true.
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=no-reply@internview.app

# Base URL of the SPA — reset links point here: <url>/reset-password?token=...
FRONTEND_URL=http://localhost:5173

# Password-reset token lifetime, minutes
RESET_TOKEN_EXP_MINUTES=30
